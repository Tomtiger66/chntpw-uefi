ls 
apk update
/sbin/apk update
export PATH=/usr/bin:/bin:/usr/sbin:/sbin
ls /
apk update
apk add linux-lts chntpw ntfsprogs grub grub-efi grub-bios kbd-keymaps util-linux pciutils usbutils e2fsprogs dosfstools
apk search ntfs
apk search kbd
apk add linux-lts chntpw ntfs-3g-progs grub grub-efi grub-bios kbd kbd-bkeymaps util-linux pciutils usbutils e2fsprogs dosfstools
cat /init
cat > /init << 'EOF'
#!/bin/sh
# Grundlegende Dateisysteme mounten
mount -t proc proc /proc
mount -t sysfs sys /sys
mount -t devtmpfs dev /dev
# PATH setzen
export PATH=/usr/bin:/bin:/usr/sbin:/sbin
# Wichtige Verzeichnisse anlegen
mkdir -p /tmp /disk
# NVMe und SCSI Module laden
modprobe nvme 2>/dev/null
modprobe nvme-core 2>/dev/null
modprobe sd_mod 2>/dev/null
# Unser Startskript aufrufen
exec /scripts/start.sh
EOF
chmod +x /init 
ls -allh
cat /init
ls -la /boot/
du -sh iso_content/
apk del linux-firmware
ls -la /lib/firmware/
rm -rf /lib/firmware/*
mkinitfs -o /boot/initramfs-lts
ls -la /boot/
ls /lib/modules/
mkinitfs -o /boot/initramfs-lts 6.18.24-0-lts
du -sh /boot/initramfs-lts
exit
